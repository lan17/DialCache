{
  "name": "@rungalileo/gcache",
  "version": "0.1.0",
  "description": "TypeScript port of GCache with explicit-context local and Redis TTL caching.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./node-redis": {
      "types": "./dist/node-redis.d.ts",
      "import": "./dist/node-redis.js",
      "require": "./dist/node-redis.cjs"
    },
    "./redis-protocol": {
      "types": "./dist/redis-protocol.d.ts",
      "import": "./dist/redis-protocol.js",
      "require": "./dist/redis-protocol.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/node-redis.ts src/redis-protocol.ts --format esm,cjs --dts --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:package": "node --input-type=module -e \"await import('@rungalileo/gcache'); await import('@rungalileo/gcache/redis-protocol'); await import('@rungalileo/gcache/node-redis')\" && node -e \"require('@rungalileo/gcache'); require('@rungalileo/gcache/redis-protocol'); require('@rungalileo/gcache/node-redis')\"",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@vitest/coverage-v8": "^4.0.14",
    "redis": "~4.7.1",
    "testcontainers": "^12.0.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  },
  "engines": {
    "node": ">=18.17"
  },
  "dependencies": {
    "prom-client": "^15.1.3"
  },
  "peerDependencies": {
    "redis": "~4.7.1"
  },
  "peerDependenciesMeta": {
    "redis": {
      "optional": true
    }
  }
}
