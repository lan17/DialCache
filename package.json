{
  "name": "dialcache",
  "version": "0.1.0",
  "description": "Fine-grained TypeScript caching with explicit local and Redis controls.",
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./node-redis": {
      "import": {
        "types": "./dist/node-redis.d.ts",
        "default": "./dist/node-redis.js"
      },
      "require": {
        "types": "./dist/node-redis.d.cts",
        "default": "./dist/node-redis.cjs"
      }
    },
    "./valkey-glide": {
      "import": {
        "types": "./dist/valkey-glide.d.ts",
        "default": "./dist/valkey-glide.js"
      },
      "require": {
        "types": "./dist/valkey-glide.d.cts",
        "default": "./dist/valkey-glide.cjs"
      }
    },
    "./redis-protocol": {
      "import": {
        "types": "./dist/redis-protocol.d.ts",
        "default": "./dist/redis-protocol.js"
      },
      "require": {
        "types": "./dist/redis-protocol.d.cts",
        "default": "./dist/redis-protocol.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "benchmark:request-local": "pnpm build && node scripts/benchmark-request-local.mjs",
    "build": "tsup src/index.ts src/node-redis.ts src/redis-protocol.ts src/valkey-glide.ts --format esm,cjs --dts --clean",
    "check": "pnpm typecheck && pnpm test:release && pnpm test && pnpm build && pnpm test:package",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:package": "node scripts/test-package.mjs",
    "test:release": "node --test scripts/release-version.test.mjs",
    "test:watch": "vitest"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "20 || >=22"
  },
  "dependencies": {
    "@types/node": "^24.10.1",
    "lru-cache": "^11.5.2",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@valkey/valkey-glide": "^2.4.2",
    "@vitest/coverage-v8": "^4.0.14",
    "redis": "~4.7.1",
    "testcontainers": "^12.0.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  },
  "peerDependencies": {
    "@valkey/valkey-glide": "^2.4.2",
    "redis": "~4.7.1"
  },
  "peerDependenciesMeta": {
    "@valkey/valkey-glide": {
      "optional": true
    },
    "redis": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lan17/DialCache.git"
  },
  "bugs": {
    "url": "https://github.com/lan17/DialCache/issues"
  },
  "homepage": "https://github.com/lan17/DialCache#readme",
  "keywords": [
    "cache",
    "redis",
    "typescript"
  ]
}
